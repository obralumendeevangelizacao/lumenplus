# Lumen+ Mobile — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA commite o .env.local no git.

# Firebase (obtenha em: Firebase Console → Configurações do projeto → Seus apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# URL da API backend (deixe vazio em dev para usar localhost)
# EXPO_PUBLIC_API_URL=https://seu-backend.up.railway.app
